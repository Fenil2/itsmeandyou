generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  source          String   @default("Hernia-Booking")
  firstName       String
  lastName        String?
  email           String?
  phone           String
  location        String?
  dateKey         String?
  appointmentDate String?
  appointmentTime String?
  symptomType     String?
  hadSurgery      String?
  prevConsult     String?
  pageUrl         String?
  paymentId       String?
  paymentStatus   String?
  telecrmStatus   String?
  telecrmPayload   Json?

  @@index([createdAt])
  @@index([phone])
  @@index([dateKey])
}
